{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nanoClaw",
  "version": "0.1.0",
  "identifier": "sg.mps.nanoclaw.client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "nanoClaw \u2014 MPS Casework",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8000 ws://127.0.0.1:8000 http://192.168.0.0/16 ws://192.168.0.0/16 ipc: http://ipc.localhost",
      "dangerousDisableAssetCspModification": false
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage",
      "dmg",
      "app"
    ],
    "category": "Productivity",
    "shortDescription": "MPS casework client for volunteers and vetters",
    "longDescription": "On-premises MPS casework client. Talks only to the LAN-local nanoClaw server (mps_server) -- no cloud calls, no constituent data leaves the LAN.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "exceptionDomain": "",
      "signingIdentity": null,
      "entitlements": null
    }
  }
}